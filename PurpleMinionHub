local survivorsFolder = workspace.Players:WaitForChild("Survivors")
local rootPart = game.Players.LocalPlayer.Character:WaitForChild("HumanoidRootPart")

local function getClosestSurvivor()
	local closestSurvivor = nil
	local closestDistance = math.huge

	for _, model in pairs(survivorsFolder:GetChildren()) do
		if model:IsA("Model") and model:FindFirstChild("HumanoidRootPart") then
			local distance = (model.HumanoidRootPart.Position - rootPart.Position).Magnitude
			if distance < closestDistance then
				closestDistance = distance
				closestSurvivor = model
			end
		end
	end

	return closestSurvivor, closestDistance
end

